{
  "UserConfig": {
    "Namespaces": [
      {
        "Name": "messaging-namespace",
        "Queues": [
          {
            "Name": "message-delivery",
            "Properties": {
              "DeadLetteringOnMessageExpiration": false,
              "DefaultMessageTimeToLive": "PT1H",
              "LockDuration": "PT1M",
              "MaxDeliveryCount": 10
            }
          }
        ]
      }
    ],
    "Logging": {
      "Type": "File"
    }
  }
}
